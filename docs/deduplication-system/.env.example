# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/deduplication
PGVECTOR_TABLE=embeddings
PGVECTOR_DIMENSION=384

# Qdrant Configuration (alternative to pgvector)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=content_embeddings
QDRANT_API_KEY=

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Deduplication Engine Configuration
SIMHASH_HASH_BITS=64
SIMHASH_HAMMING_THRESHOLD=3
SIMHASH_SHINGLE_SIZE=4

MINHASH_NUM_HASHES=128
MINHASH_SHINGLE_SIZE=3
MINHASH_JACCARD_THRESHOLD=0.85

SEMANTIC_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_VECTOR_DIMENSION=384
SEMANTIC_COSINE_THRESHOLD=0.92

# Author Resolution
AUTHOR_MIN_CONFIDENCE=0.75

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Performance Tuning
BATCH_SIZE=100
MAX_CONCURRENT_REQUESTS=10
CACHE_TTL=3600
